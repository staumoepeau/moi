      "url": "/desk/qms_terminal",
      "icons": [
        {
          "src": "/assets/moi/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Submit Feedback",
      "short_name": "Feedback",
      "description": "Submit feedback about your service experience",
      "url": "/desk/qms_terminal?view=feedback",
